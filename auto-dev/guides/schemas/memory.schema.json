{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Memory Entry Schema",
  "description": "记忆条目定义",
  "type": "object",
  "required": ["id", "type", "content", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(MEM|SELF|CORR|PROJ)-\\d{8}-\\d{3,6}$",
      "description": "记忆ID"
    },
    "type": {
      "type": "string",
      "enum": ["episodic", "working", "longterm", "correction", "decision", "knowledge"],
      "description": "记忆类型"
    },
    "tier": {
      "type": "string",
      "enum": ["hot", "warm", "cold"],
      "description": "存储层级"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "description": "记忆内容"
    },
    "title": {
      "type": "string",
      "description": "记忆标题"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "标签"
    },
    "importance": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "重要性 1-10"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "accessed_at": {
      "type": "string",
      "format": "date-time"
    },
    "access_count": {
      "type": "integer",
      "minimum": 0
    },
    "related": {
      "type": "array",
      "items": {"type": "string"},
      "description": "关联记忆ID"
    },
    "derived_from": {
      "type": "array",
      "items": {"type": "string"},
      "description": "派生于"
    },
    "supersedes": {
      "type": "array",
      "items": {"type": "string"},
      "description": "替代"
    }
  }
}
